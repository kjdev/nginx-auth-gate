ngx_addon_name=ngx_http_auth_gate_module

# --- submodule: nxe-json ---
nxe_json_dir="$ngx_addon_dir/nxe-json"

if [ ! -f "$nxe_json_dir/config.ngx" ]; then
    echo "$0: error: $nxe_json_dir/config.ngx not found" >&2
    exit 1
fi

. "$nxe_json_dir/config.ngx"

# --- submodule: nxe-jwx ---
nxe_jwx_dir="$ngx_addon_dir/nxe-jwx"

if [ ! -f "$nxe_jwx_dir/config.ngx" ]; then
    echo "$0: error: $nxe_jwx_dir/config.ngx not found" >&2
    exit 1
fi

. "$nxe_jwx_dir/config.ngx"

# --- module definition ---
ngx_module_type=HTTP
ngx_module_name="ngx_http_auth_gate_module"
ngx_module_deps="\
  $nxe_json_module_deps \
  $nxe_jwx_module_deps \
"
ngx_module_incs="\
  $nxe_json_module_incs \
  $nxe_jwx_module_incs \
  $ngx_addon_dir/src \
"
ngx_module_srcs="\
  $nxe_json_module_srcs \
  $nxe_jwx_module_srcs \
  $ngx_addon_dir/src/ngx_auth_gate_field.c \
  $ngx_addon_dir/src/ngx_auth_gate_operator.c \
  $ngx_addon_dir/src/ngx_http_auth_gate_module.c \
"

ngx_module_libs="\
  $nxe_json_module_libs \
  $nxe_jwx_module_libs \
"

. auto/module
