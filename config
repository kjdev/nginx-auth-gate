ngx_addon_name=ngx_http_auth_gate_module

ngx_module_type=HTTP
ngx_module_name="ngx_http_auth_gate_module"
ngx_module_deps=
ngx_module_incs="$ngx_addon_dir/src"
ngx_module_srcs="\
  $ngx_addon_dir/src/ngx_auth_gate_json.c \
  $ngx_addon_dir/src/ngx_auth_gate_jwt.c \
  $ngx_addon_dir/src/ngx_auth_gate_jwks.c \
  $ngx_addon_dir/src/ngx_auth_gate_jws.c \
  $ngx_addon_dir/src/ngx_auth_gate_field.c \
  $ngx_addon_dir/src/ngx_auth_gate_operator.c \
  $ngx_addon_dir/src/ngx_http_auth_gate_module.c \
"

# Explicitly link the PCRE library for musl (Alpine Linux) compatibility.
# musl's dlopen does not expose symbols from the main binary to dynamic modules.
# Redundant but harmless on glibc.
# Use nginx's $PCRE_LIBRARY to match the backend nginx chose during configure.
if [ "$PCRE_LIBRARY" = 'PCRE2' ]; then
    _pcre_lib='-lpcre2-8'
elif [ "$PCRE_LIBRARY" = 'PCRE' ]; then
    _pcre_lib='-lpcre'
else
    _pcre_lib=
fi

ngx_module_libs="\
  PCRE \
  $_pcre_lib \
  -ljansson \
  -lcrypto \
"

. auto/module
